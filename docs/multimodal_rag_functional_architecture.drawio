          <mxGeometry x="245" y="330" width="190" height="88" as="geometry" />
        </mxCell>
        <mxCell id="mode_policy" value="三层模式&#xa;Direct：直接回答&#xa;Retrieval：单轮或双轮检索&#xa;Agentic：规划、反思、再检索" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f2e9ff;strokeColor=#7b2cbf;fontColor=#172033;fontSize=12;fontStyle=1;" vertex="1" parent="lane_control">
