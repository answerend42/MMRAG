        <mxCell id="evidence_check" value="证据覆盖检查&#xa;覆盖率不足：扩展查询&#xa;证据冲突：触发反思&#xa;证据足够：进入生成" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#f77f00;fontColor=#172033;fontSize=12;" vertex="1" parent="lane_retrieval">
