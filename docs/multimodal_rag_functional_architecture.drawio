        <mxCell id="direct_mode" value="Direct Mode&#xa;内部知识足够时直接回答&#xa;不强制检索" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#f77f00;fontColor=#172033;fontSize=12;" vertex="1" parent="lane_control">
