        <mxCell id="dep_scope" value="Scope：表达服务、工作节点、数据库、队列、模型网关和监控在网络/安全区域中的部署关系；不表达业务流程细节。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#172033;fontSize=13;" vertex="1" parent="1"><mxGeometry x="120" y="78" width="1960" height="46" as="geometry" /></mxCell>

